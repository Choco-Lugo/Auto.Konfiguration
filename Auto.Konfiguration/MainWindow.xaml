<Window x:Class="Auto.Konfiguration.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Auto.Konfiguration"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Title="MainWindow" Height="860" Width="1420">
    <DockPanel>

        <Grid DockPanel.Dock="Top" Background="#1E1E2F">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Menu Grid.Column="0"
                    Background="#1E1E2F"
                    Foreground="#FF2196F3"
                    FontWeight="Bold">

                <MenuItem Header="_Datei">
                    <MenuItem Header="Neu" Foreground="Black"/>
                    <MenuItem Header="Öffnen" Foreground="Black"/>
                    <Separator/>
                    <MenuItem Header="Beenden" Foreground="Black" />
                </MenuItem>
            </Menu>

            <Border Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0"
                    Padding="10,6"
                    CornerRadius="14"
                    Background="#22000000">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="👤"
                               Foreground="#FF2196F3"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Volker Lugo"
                               Foreground="#FF2196F3"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Background="#1E1E2F" VerticalAlignment="Stretch">
                <TextBlock Text="Auto-Konfigurator"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#FF2196F3"
                           Margin="10,30,0,40"/>

                <Button Content="Konfiguration"
                        Margin="10"
                        Command="{Binding NavigateKonfiCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"/>

                <Button Content="Übersicht"
                        Margin="10"
                        Command="{Binding NavigateUebersichtCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"/>

                <StackPanel VerticalAlignment="Bottom" Margin="10,50,0,20">
                    <TextBlock Text="Version 2026.3"
                               Foreground="#888"
                               FontSize="12"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Column="1">
                <ContentControl Content="{Binding CurrentViewModel}" />
            </Grid>
        </Grid>

    </DockPanel>
</Window>
