<UserControl x:Class="Auto.Konfiguration.Views.CarKonfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Auto.Konfiguration.Views"
             mc:Ignorable="d" 
             MinHeight="400" MinWidth="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--Motor-->
            <materialDesign:Card Margin="10" Padding="15"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Motorleistung"
                                   Background="#FF2196F3"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" Height="28"/>

                    <TextBlock Text="{Binding SelectedEngine.Power, StringFormat='{}Gewählt: {0} PS'}"
                               Margin="0,5,0,10"
                               FontWeight="Bold"/>

                    <ListBox Grid.Row="1"
                                 ItemsSource="{Binding engines}"
                                 SelectedItem="{Binding SelectedEngine}"
                                 DisplayMemberPath="Power"
                                 Style="{StaticResource MaterialDesignListBox}">
                        
                    </ListBox>
                </StackPanel>
            </materialDesign:Card>

            <!--Lackierung-->
            <materialDesign:Card Grid.Column="1" Margin="10" Padding="15"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Lackierung"
                                   Background="#FF2196F3"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" Height="28"/>

                    <TextBlock Text="{Binding SelectedPaint.Name, StringFormat='{}Gewählt: {0}'}"
                               Margin="0,5,0,10"
                               FontWeight="Bold"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding paints}"
                             SelectedItem="{Binding SelectedPaint}"
                             DisplayMemberPath="Name"
                             Style="{StaticResource MaterialDesignListBox}"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--Felgen-->
            <materialDesign:Card Grid.Column="0" Margin="10" Padding="15"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Felgen"
                                   Background="#FF2196F3"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" Height="28"/>

                    <TextBlock Text="{Binding SelectedRims.Name, StringFormat='{}Gewählt: {0}'}"
                               Margin="0,5,0,10"
                               FontWeight="Bold"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding rims}"
                             SelectedItem="{Binding SelectedRims}"
                             DisplayMemberPath="Name"
                             Style="{StaticResource MaterialDesignListBox}"/>
                </StackPanel>
            </materialDesign:Card>

            <!--Extras-->
            <materialDesign:Card Grid.Column="1" Margin="10" Padding="15"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Sonderausstattung"
                                   Background="#FF2196F3"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" Height="28"/>

                    <ItemsControl ItemsSource="{Binding SelectedOptionalEquipment}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ScrollViewer 
                      VerticalScrollBarVisibility="Auto">
                        <ListBox Grid.Row="1"
                             ItemsSource="{Binding extras}"
                             SelectionMode="Multiple"
                             DisplayMemberPath="Name"
                             SelectionChanged="Extras_SelectionChanged"
                             Margin="0,0,0,0"
                             Style="{StaticResource MaterialDesignListBox}"/>
                    </ScrollViewer>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <materialDesign:Card Grid.Row="2" Margin="10" Padding="20"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Gesamtpreis"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"/>

                    <TextBlock Text="{Binding TotalPreice, StringFormat={}{0:C}, ConverterCulture=de-DE}"
                               FontSize="28"
                               FontWeight="Bold"/>

                </StackPanel>

                <Button Content="Kofiguration speichern"
                            Command="{Binding SaveConfigCommand}"
                            Width="200"
                            Height="50"
                            DockPanel.Dock="Right"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
            </DockPanel>
        </materialDesign:Card>

    </Grid>
</UserControl>
