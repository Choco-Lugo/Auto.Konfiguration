<UserControl x:Class="Auto.Konfiguration.Views.CarCompleteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Auto.Konfiguration.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             MinHeight="700" MinWidth="1000">
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!--LOAD CONFIG--> 
        <materialDesign:Card Padding="15" Margin="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal">

                    <TextBox Width="300"
                             Margin="0,0,10,0"
                         
                             Text="{Binding InputUrl}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                    <Button Content="Laden"
                            Command="{Binding LoadConfigurationCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                </StackPanel>

                <!--URL Anzeige-->
                <TextBlock Text="{Binding GeneratedUrl}"
                       Margin="0,10,0,0"
                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
            </StackPanel>
        </materialDesign:Card>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!--MOTOR-->
            <materialDesign:Card Grid.Row="0" Grid.Column="0" Margin="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Motor"
                               Background="#FF2196F3"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}" Height="28"/>

                    <TextBlock Text="{Binding Config.Engine.Power, StringFormat='{} {0} PS'}"
                       FontWeight="Bold"/>
                </StackPanel>
            </materialDesign:Card>

            <!--LACK-->
            <materialDesign:Card Grid.Row="0" Grid.Column="1" Margin="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Lackierung"
                               Background="#FF2196F3"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}" Height="28"/>

                    <TextBlock Text="{Binding Config.Paint.Name}"
                       FontWeight="Bold"/>
                </StackPanel>
            </materialDesign:Card>

            <!--FELGEN-->
            <materialDesign:Card Grid.Row="1" Grid.Column="0" Margin="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Felgen"
                               Background="#FF2196F3"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}" Height="28"/>

                    <TextBlock Text="{Binding Config.Rims.Name}"
                       FontWeight="Bold"/>
                </StackPanel>
            </materialDesign:Card>

            <!--EXTRAS-->
            <materialDesign:Card Grid.Row="1" Grid.Column="1" Margin="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Sonderausstattung"
                               Background="#FF2196F3"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}" Height="28"/>

                    <ItemsControl ItemsSource="{Binding Config.OptionalEquipment}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name, StringFormat=• {0}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </materialDesign:Card>

        </Grid>

        <!--PREIS-->
        <materialDesign:Card Grid.Row="2" Margin="10" Padding="20">
            <DockPanel>

                <StackPanel DockPanel.Dock="Left" Margin="0,0,20,0">
                    <TextBlock Text="Gesamtpreis"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"/>

                    <TextBlock Text="{Binding Config.TotalPrice, StringFormat={}{0:C}, ConverterCulture=de-DE}"
                               FontSize="30"
                               FontWeight="Bold"/>
                </StackPanel>

                <Button Content="Zurück"
                        Command="{Binding BackConfigurationCommand}"
                        DockPanel.Dock="Right"
                        Style="{StaticResource MaterialDesignFlatButton}"/>
            </DockPanel>
        </materialDesign:Card>

    </Grid>
</UserControl>
